{
  "manifest_version": 3,
  "name": "Copy selected text and url",
  "short_name": "Copy selected text and url",
  "description": "Add a shortcut and context menu item to copy selected text and url to clipboard.",
  "version": "2.0",
  "homepage_url": "https://github.com/sinCereXuYuan/webext-copy-title-url",
  "author": "Lei & Marek Jedliński",

  "commands": {
    "copy-selection-and-url": {
      "suggested_key": {
        "default": "Alt+C",
        "mac": "Alt+C"
      },
      "description": "Copy selection as markdown"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "48": "icons/copy_title_and_url.png"
  },

  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "clipboardWrite",
    "clipboardRead"
  ]
}

